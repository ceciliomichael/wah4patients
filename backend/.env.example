# Runtime mode: development | test | production
NODE_ENV=development

# HTTP port where NestJS API will listen.
PORT=3000

# Allowed CORS origins for frontend clients.
# Comma-separated if multiple, e.g. http://localhost:3001,http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3001

# Shared secret that the frontend sends as x-api-key on every backend request.
# This is not a user password, but it should still be treated as sensitive.
# Generate with: openssl rand -base64 48
BACKEND_API_KEY=replace_with_a_long_random_api_key

# Supabase project URL (Dashboard -> Project Settings -> API -> Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key (Dashboard -> Project Settings -> API -> publishable key).
SUPABASE_PUBLISHABLE_KEY=replace_with_supabase_publishable_key

# Supabase secret key (secret, backend-only, never expose to frontend).
SUPABASE_SECRET_KEY=replace_with_supabase_secret_key

# Resend API key used to send OTP emails (starts with re_)
RESEND_API_KEY=re_replace_with_resend_api_key

# Verified sender identity in Resend.
# Format examples: auth@yourdomain.com OR WAH4P Auth <auth@yourdomain.com>
RESEND_FROM_EMAIL=WAH4P Auth <auth@yourdomain.com>

# OTP validity window in minutes.
OTP_TTL_MINUTES=10

# Minimum wait before user can request a new OTP.
OTP_RESEND_COOLDOWN_SECONDS=45

# Max invalid OTP attempts before requiring a new OTP.
OTP_MAX_ATTEMPTS=5

# Secret used to hash OTP values before database storage.
# Must be long and random. Keep private.
OTP_HASH_SECRET=replace_with_a_random_secret_for_otp_hashing

# Secret used to sign temporary registration tokens (JWT).
# Must be long and random. Keep private.
REGISTRATION_TOKEN_SECRET=replace_with_a_random_secret_for_registration_tokens

# Lifetime of registration token returned after OTP verification.
REGISTRATION_TOKEN_TTL_SECONDS=900
