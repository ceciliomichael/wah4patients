# This file is kept only as documentation for the runtime config values.
# The app now reads these values from the root frontend/.env file at runtime.

# Full backend base URL including API prefix.
BACKEND_BASE_URL=http://localhost:3045/api/v1

# Shared secret that the Flutter app sends as x-api-key on backend requests.
# This must match backend BACKEND_API_KEY exactly.
BACKEND_API_KEY=replace_with_the_same_backend_api_key
